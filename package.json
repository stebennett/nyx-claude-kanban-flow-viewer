{
  "name": "kanban-flow-viewer",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "kanban-flow-viewer": "dist/server/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stebennett/nyx-claude-flow-viewer.git"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build:ui": "vite build",
    "build:server": "tsc -b tsconfig.server.json --force",
    "build": "npm run build:ui && npm run build:server"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "globals": "^15.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@types/node": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "fast-check": "^3.23.0",
    "js-yaml": "^4.1.0",
    "@types/js-yaml": "^4.0.0"
  }
}
