    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node"],
    "outDir": "dist/server",
    "rootDir": "src/server",
    "composite": true,
    "declaration": true
  },
  "include": ["src/server/**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
