{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node"],
    "noEmit": true,
    "composite": true
  },
  "include": [
    "test/**/*.ts",
    "src/server/**/*.test.ts",
    "src/server/paths.ts",
    "src/server/card-model.ts",
    "src/server/parse-card.ts",
    "src/server/build-snapshot.ts",
    "src/server/milestones.ts",
    "vite.config.ts"
  ]
}
